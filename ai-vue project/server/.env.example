# ============================================
# AI Mental Health API — 环境变量配置模板
# 复制此文件为 .env 后修改配置值
# cp .env.example .env
# ============================================

# 应用
APP_NAME=AI Mental Health API
APP_ENV=development
PORT=8000

# 数据库（开发期使用 SQLite，生产切换 MySQL）
# SQLite: file:./dev.db
# MySQL:  mysql://user:password@localhost:3306/ai_vue
DATABASE_URL=file:./dev.db

# JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=1440m

# DeepSeek AI（留空则使用 mock AI 模式）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 初始管理员账号（仅 prisma seed 使用）
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
