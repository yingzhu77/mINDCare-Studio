# ============================================
# AI Mental Health API — 生产环境配置
# 复制此文件为 .env 并修改配置值
# cp .env.production .env
# ============================================

# 应用
APP_NAME=AI Mental Health API
APP_ENV=production
PORT=8000

# 数据库（生产环境使用 MySQL）
DATABASE_URL=mysql://ai_vue_user:your-password@mysql:3306/ai_vue?charset=utf8mb4

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=1440m

# DeepSeek AI（留空则使用 mock AI 模式）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 初始管理员账号（仅 prisma seed 使用）
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
