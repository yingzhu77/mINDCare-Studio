{
  "name": "ai-vue-server",
  "version": "2.6.0",
  "private": true,
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:generate:mysql": "prisma generate --schema=prisma/mysql/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:mysql": "prisma migrate dev --schema=prisma/mysql/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:deploy:mysql": "prisma migrate deploy --schema=prisma/mysql/schema.prisma",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:mysql": "prisma db seed --schema=prisma/mysql/schema.prisma",
    "prisma:studio": "prisma studio",
    "prisma:studio:mysql": "prisma studio --schema=prisma/mysql/schema.prisma",
    "test": "jest --config jest.config.ts --forceExit",
    "test:unit": "jest --config jest.config.ts --testPathIgnorePatterns=\"e2e\" --forceExit",
    "test:e2e": "jest --config jest.config.ts --forceExit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^5.18.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "description": "NestJS backend for the AI mental health assistant.",
  "license": "MIT"
}
