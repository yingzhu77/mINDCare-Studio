# ============================================
# AI Mental Health API — 环境变量配置模板
# 复制此文件为 .env 后修改配置值
# cp .env.example .env
# ============================================

# 应用
APP_NAME=AI Mental Health API
APP_ENV=development
PORT=8000

# 数据库
# 开发期使用 SQLite: file:./dev.db
# 生产环境切换 MySQL:
#   DATABASE_URL=mysql://user:password@localhost:3306/ai_vue?charset=utf8mb4
#   然后使用专用 MySQL schema 文件执行迁移:
#   npm run prisma:migrate:deploy:mysql
#   npm run prisma:generate:mysql
DATABASE_URL=file:./dev.db

# JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=1440m

# DeepSeek AI（留空则使用 mock AI 模式）
# 注意：deepseek-chat 将于 2026-07-24 弃用，新项目统一使用 deepseek-v4-flash
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 危机心理援助热线（用于 AI 系统提示词中的热线信息）
# 当用户表达自伤/自杀等高风险意图时，AI 优先提供以下资源
# CRISIS_HOTLINE=400-161-9995
# CRISIS_HOTLINE_NAME=全国心理援助热线

# 初始管理员账号（仅 prisma seed 使用）
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
