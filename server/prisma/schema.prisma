generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String
  role         String    @default("user") // "admin" | "user"
  status       Int       @default(1)      // 1=启用 0=禁用
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // 关联
  articles        KnowledgeArticle[]  @relation("ArticleAuthor")
  reviewedArticles KnowledgeArticle[] @relation("ArticleReviewer")
  chatSessions    ChatSession[]
  emotionDiaries  EmotionDiary[]
  analysisResults AiAnalysisResult[]
  notifications    Notification[]

  @@map("users")
}

model KnowledgeCategory {
  id           Int       @id @default(autoincrement())
  categoryName String
  parentId     Int?
  sortOrder    Int       @default(0)
  status       Int       @default(1) // 1=启用 0=禁用
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  parent       KnowledgeCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     KnowledgeCategory[] @relation("CategoryTree")
  articles     KnowledgeArticle[]

  @@map("knowledge_categories")
}

model KnowledgeArticle {
  id           Int       @id @default(autoincrement())
  title        String
  categoryId   Int?
  authorId     Int
  reviewerId   Int?
  summary      String?
  tags         String?   // JSON 字符串数组
  coverImage   String?
  content      String?
  readCount    Int       @default(0)
  status       String    @default("draft") // draft | pending_review | published | rejected | offline
  rejectReason String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  category  KnowledgeCategory? @relation(fields: [categoryId], references: [id])
  author    User               @relation("ArticleAuthor", fields: [authorId], references: [id])
  reviewer  User?              @relation("ArticleReviewer", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([authorId])
  @@map("knowledge_articles")
}

model ChatSession {
  id           Int       @id @default(autoincrement())
  sessionId    String    @unique
  userId       Int
  userName     String?
  startTime    DateTime  @default(now())
  endTime      DateTime?
  messageCount Int       @default(0)
  emotionTags  String?   // JSON 字符串数组
  aiSummary    String?
  riskLevel    String?
  status       String    @default("active") // active | closed
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user      User           @relation(fields: [userId], references: [id])
  messages  ChatMessage[]
  analyses  AiAnalysisResult[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id          Int      @id @default(autoincrement())
  sessionId   String
  role        String   // user | assistant
  content     String
  messageTime DateTime @default(now())
  rawPayload  String?  // JSON，保留模型原始返回
  createdAt   DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [sessionId])

  @@index([sessionId])
  @@map("chat_messages")
}

model EmotionDiary {
  id              Int      @id @default(autoincrement())
  userId          Int
  userName        String?
  diaryDate       String
  moodScore       Int?
  sleepQuality    Int?
  stressLevel     Int?
  dominantEmotion String?
  emotionTriggers String?
  diaryContent    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id])
  analyses  AiAnalysisResult[]

  @@map("emotion_diaries")
}

model AiAnalysisResult {
  id                     Int       @id @default(autoincrement())
  bizType                String    // emotion_diary | chat_session
  bizId                  Int
  mainEmotion            String?
  emotionIntensity       Int?
  emotionNature          String?   // positive | negative | neutral
  riskLevel              String?   // low | medium | high | critical
  riskDescription        String?
  professionalAdvice     String?
  improvementSuggestions String?
  summary                String?
  emotionTags            String?   // JSON 字符串数组
  modelName              String?
  rawResponse            String?
  status                 String    @default("pending") // pending | success | failed
  errorMessage           String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user           User          @relation(fields: [userId], references: [id])
  userId         Int
  emotionDiary   EmotionDiary? @relation(fields: [emotionDiaryId], references: [id])
  emotionDiaryId Int?
  chatSession    ChatSession?  @relation(fields: [chatSessionId], references: [id])
  chatSessionId  Int?

  @@index([bizType, bizId])
  @@map("ai_analysis_results")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   @default("article_review") // article_review | system
  title     String
  content   String?
  relatedId Int?                               // 关联业务 ID（如文章ID）
  isRead    Int      @default(0)               // 0=未读 1=已读
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}
