generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(50)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @db.VarChar(255)
  role         String    @default("user") @db.VarChar(10)
  status       Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  articles         KnowledgeArticle[]           @relation("ArticleAuthor")
  reviewedArticles KnowledgeArticle[]           @relation("ArticleReviewer")
  revisionAuthor   KnowledgeArticleRevision[]   @relation("RevisionAuthor")
  revisionReviewer KnowledgeArticleRevision[]   @relation("RevisionReviewer")
  chatSessions     ChatSession[]
  emotionDiaries   EmotionDiary[]
  analysisResults  AiAnalysisResult[]
  notifications    Notification[]

  @@map("users")
}

model KnowledgeCategory {
  id           Int       @id @default(autoincrement())
  categoryName String    @db.VarChar(100)
  parentId     Int?
  sortOrder    Int       @default(0)
  status       Int       @default(1)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  parent   KnowledgeCategory?          @relation("CategoryTree", fields: [parentId], references: [id])
  children KnowledgeCategory[]         @relation("CategoryTree")
  articles KnowledgeArticle[]
  revisions KnowledgeArticleRevision[]

  @@map("knowledge_categories")
}

model KnowledgeArticle {
  id           Int       @id @default(autoincrement())
  title        String    @db.VarChar(200)
  categoryId   Int?
  authorId     Int
  reviewerId   Int?
  summary      String?   @db.Text
  tags         String?   @db.VarChar(500)
  coverImage   String?   @db.VarChar(500)
  content      String?   @db.LongText
  readCount    Int       @default(0)
  status       String    @default("draft") @db.VarChar(20)
  rejectReason String?   @db.Text
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  category KnowledgeCategory? @relation(fields: [categoryId], references: [id])
  author   User               @relation("ArticleAuthor", fields: [authorId], references: [id])
  reviewer User?              @relation("ArticleReviewer", fields: [reviewerId], references: [id])
  revisions KnowledgeArticleRevision[]

  @@index([status])
  @@index([authorId])
  @@map("knowledge_articles")
}

model KnowledgeArticleRevision {
  id           Int       @id @default(autoincrement())
  articleId    Int
  authorId     Int
  reviewerId   Int?
  title        String    @db.VarChar(200)
  categoryId   Int?
  summary      String?   @db.Text
  tags         String?   @db.VarChar(500)
  coverImage   String?   @db.VarChar(500)
  content      String?   @db.LongText
  status       String    @default("pending_review") @db.VarChar(20) // pending_review | published | rejected
  rejectReason String?   @db.Text
  submittedAt  DateTime  @default(now())
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  article  KnowledgeArticle?  @relation(fields: [articleId], references: [id])
  category KnowledgeCategory? @relation(fields: [categoryId], references: [id])
  author   User               @relation("RevisionAuthor", fields: [authorId], references: [id])
  reviewer User?              @relation("RevisionReviewer", fields: [reviewerId], references: [id])

  @@index([status])
  @@index([articleId, status])
  @@map("knowledge_article_revisions")
}

model ChatSession {
  id           Int       @id @default(autoincrement())
  sessionId    String    @unique @db.VarChar(100)
  userId       Int
  userName     String?   @db.VarChar(50)
  startTime    DateTime  @default(now())
  endTime      DateTime?
  messageCount Int       @default(0)
  emotionTags  String?   @db.VarChar(500)
  aiSummary    String?   @db.Text
  riskLevel    String?   @db.VarChar(20)
  status       String    @default("active") @db.VarChar(20)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user     User               @relation(fields: [userId], references: [id])
  messages ChatMessage[]
  analyses AiAnalysisResult[]

  @@map("chat_sessions")
}

model ChatMessage {
  id          Int      @id @default(autoincrement())
  sessionId   String   @db.VarChar(100)
  role        String   @db.VarChar(20)
  content     String   @db.LongText
  messageTime DateTime @default(now())
  rawPayload  String?  @db.LongText
  createdAt   DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [sessionId])

  @@index([sessionId])
  @@map("chat_messages")
}

model EmotionDiary {
  id              Int      @id @default(autoincrement())
  userId          Int
  userName        String?  @db.VarChar(50)
  diaryDate       String   @db.VarChar(20)
  moodScore       Int?
  sleepQuality    Int?
  stressLevel     Int?
  dominantEmotion String?  @db.VarChar(50)
  emotionTriggers String?  @db.Text
  diaryContent    String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User                @relation(fields: [userId], references: [id])
  analyses AiAnalysisResult[]

  @@map("emotion_diaries")
}

model AiAnalysisResult {
  id                     Int       @id @default(autoincrement())
  bizType                String    @db.VarChar(30)
  bizId                  Int
  mainEmotion            String?   @db.VarChar(50)
  emotionIntensity       Int?
  emotionNature          String?   @db.VarChar(20)
  riskLevel              String?   @db.VarChar(20)
  riskDescription        String?   @db.Text
  professionalAdvice     String?   @db.Text
  improvementSuggestions String?   @db.Text
  summary                String?   @db.Text
  emotionTags            String?   @db.VarChar(500)
  modelName              String?   @db.VarChar(100)
  rawResponse            String?   @db.LongText
  status                 String    @default("pending") @db.VarChar(20)
  errorMessage           String?   @db.Text
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user           User          @relation(fields: [userId], references: [id])
  userId         Int
  emotionDiary   EmotionDiary? @relation(fields: [emotionDiaryId], references: [id])
  emotionDiaryId Int?
  chatSession    ChatSession?  @relation(fields: [chatSessionId], references: [id])
  chatSessionId  Int?

  @@index([bizType, bizId])
  @@map("ai_analysis_results")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   @default("article_review") @db.VarChar(30)
  title     String   @db.VarChar(200)
  content   String?  @db.Text
  relatedId Int?                                // 关联业务 ID（如文章ID）
  isRead    Int      @default(0)                // 0=未读 1=已读
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}
